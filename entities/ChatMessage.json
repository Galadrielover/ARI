{
  "name": "ChatMessage",
  "type": "object",
  "properties": {
    "role": {
      "type": "string",
      "enum": [
        "user",
        "assistant"
      ],
      "description": "Who sent the message"
    },
    "content": {
      "type": "string",
      "description": "Message content"
    },
    "sources": {
      "type": "array",
      "items": {
        "type": "string"
      },
      "description": "Referenced file or note titles"
    }
  },
  "required": [
    "role",
    "content"
  ]
}
